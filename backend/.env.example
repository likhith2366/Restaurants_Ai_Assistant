# =============================================================================
# AI provider — set ONE of these. If both are set, Anthropic wins by default
# (override with AI_PROVIDER below). With no keys, the server uses a
# deterministic fallback parser so the demo still works offline.
# =============================================================================

# Option A — Anthropic Claude
# Get a key: https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Option B — Google Gemini
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional — force a specific provider regardless of which keys are set.
# Values: anthropic | gemini | fallback
AI_PROVIDER=

# Port the API listens on. Mobile app defaults to this.
PORT=3001
